#!/usr/bin/env bash
# List all installable versions of skill-audit-mcp.
# Pulls release tags from the upstream GitHub repo.
set -euo pipefail

REPO="${SKILL_AUDIT_MCP_REPO:-https://github.com/eltociear/skill-audit-mcp.git}"

git ls-remote --tags --refs "$REPO" \
  | awk -F/ '{print $NF}' \
  | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+$' \
  | sed 's/^v//' \
  | sort -V \
  | tr '\n' ' '
echo
